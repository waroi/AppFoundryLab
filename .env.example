# Infrastructure
POSTGRES_DB=appfoundrylab
POSTGRES_USER=appfoundrylab
POSTGRES_PASSWORD=appfoundrylab_secure_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
PG_POOL_MAX_CONNS=20
PG_POOL_MIN_CONNS=2
PG_POOL_MAX_CONN_LIFETIME_MIN=30
PG_POOL_MAX_CONN_IDLE_TIME_MIN=5

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password

MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=mongo_secure_password
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=appfoundrylab_logs
MONGO_COLLECTION=request_logs
MONGO_INCIDENT_COLLECTION=incident_events

# Services
API_GATEWAY_PORT=8080
LOGGER_PORT=8090
CALCULATOR_PORT=7070
DOCKER_HOST_BIND_ADDRESS=127.0.0.1
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
MONGO_HOST_PORT=27017
LOGGER_HOST_PORT=8090
CALCULATOR_HOST_PORT=7070
API_GATEWAY_HOST_PORT=8080
FRONTEND_HOST_PORT=4321
WORKER_GRPC_ENDPOINT=calculator:7070
WORKER_GRPC_TLS_MODE=mtls
WORKER_GRPC_SERVER_NAME=calculator
WORKER_GRPC_CA_CERT_PATH=/app/certs/dev/ca.crt
WORKER_GRPC_CLIENT_CERT_PATH=/app/certs/dev/client.crt
WORKER_GRPC_CLIENT_KEY_PATH=/app/certs/dev/client.key
WORKER_GRPC_SERVER_CERT_PATH=/app/certs/dev/server.crt
WORKER_GRPC_SERVER_KEY_PATH=/app/certs/dev/server.key
WORKER_GRPC_CLIENT_CA_CERT_PATH=/app/certs/dev/ca.crt

LOGGER_ENDPOINT=http://logger:8090/ingest
LOGGER_SHARED_SECRET=change_this_logger_shared_secret
LOGGER_ALLOW_UNSIGNED_INGEST=false

# Auth & Security
JWT_SECRET=replace_with_long_random_secret
JWT_ISSUER=appfoundrylab
JWT_AUDIENCE=appfoundrylab-clients
JWT_TTL_SECONDS=3600
JWT_LEEWAY_SECONDS=15
LOCAL_AUTH_MODE=generated
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=admin_dev_password
BOOTSTRAP_USER=developer
BOOTSTRAP_USER_PASSWORD=developer_dev_password
RUNTIME_PROFILE=standard
ALLOWED_ORIGINS=http://localhost:4321,http://127.0.0.1:4321
AUTH_RATE_LIMIT_PER_MINUTE=30
API_RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_STORE=memory
RATE_LIMIT_REDIS_FAILURE_MODE=open
HEALTH_READY_CACHE_TTL_MS=1000
HEALTH_READY_STALE_IF_ERROR_MS=10000
POSTGRES_AUTO_MIGRATE=true
API_LEGACY_DEPRECATION_DATE=Fri, 27 Feb 2026 00:00:00 GMT
API_LEGACY_SUNSET_DATE=Tue, 30 Jun 2026 23:59:59 GMT

# Frontend runtime
PUBLIC_API_BASE_URL=http://localhost:8080
PUBLIC_API_RETRY_MAX_ATTEMPTS=2
PUBLIC_API_RETRY_BASE_DELAY_MS=200
PUBLIC_API_CIRCUIT_FAILURE_THRESHOLD=5
PUBLIC_API_CIRCUIT_COOLDOWN_MS=15000

MAX_REQUEST_BODY_BYTES=1048576
LOGGER_QUEUE_SIZE=2048
LOGGER_WORKERS=4
LOGGER_RETRY_MAX=1
LOGGER_RETRY_BACKOFF_BASE_MS=50
LOGGER_RETRY_BACKOFF_MAX_MS=500
LOGGER_DROP_ALERT_THRESHOLD_PCT=10
INCIDENT_EVENT_SINK=logger
INCIDENT_EVENT_INTERVAL_MS=10000
INCIDENT_EVENT_DEDUPE_WINDOW_SECONDS=300
INCIDENT_EVENT_WEBHOOK_URL=
INCIDENT_EVENT_WEBHOOK_HMAC_SECRET=
INCIDENT_EVENT_WEBHOOK_ALLOWED_HOSTS=
INCIDENT_EVENT_RETENTION_DAYS=30
MAX_INFLIGHT_REQUESTS=256
LOAD_SHED_EXEMPT_PREFIXES=/health,/metrics

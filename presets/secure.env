# secure profile: hardened baseline
RUNTIME_PROFILE=secure
STRICT_DEPENDENCIES=true
WORKER_GRPC_TLS_MODE=mtls
AUTH_RATE_LIMIT_PER_MINUTE=15
API_RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_STORE=redis
RATE_LIMIT_REDIS_FAILURE_MODE=closed
POSTGRES_AUTO_MIGRATE=true
API_LEGACY_DEPRECATION_DATE=Fri, 27 Feb 2026 00:00:00 GMT
API_LEGACY_SUNSET_DATE=Tue, 30 Jun 2026 23:59:59 GMT
HEALTH_READY_CACHE_TTL_MS=500
HEALTH_READY_STALE_IF_ERROR_MS=3000
LOGGER_RETRY_MAX=3
LOGGER_RETRY_BACKOFF_BASE_MS=75
LOGGER_RETRY_BACKOFF_MAX_MS=1000
LOGGER_WORKERS=6
LOGGER_DROP_ALERT_THRESHOLD_PCT=5
JWT_LEEWAY_SECONDS=5
LOGGER_ALLOW_UNSIGNED_INGEST=false
MAX_INFLIGHT_REQUESTS=128
LOAD_SHED_EXEMPT_PREFIXES=/health,/metrics

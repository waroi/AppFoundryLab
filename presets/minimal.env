# minimal profile: local development speed
RUNTIME_PROFILE=minimal
STRICT_DEPENDENCIES=false
WORKER_GRPC_TLS_MODE=insecure
AUTH_RATE_LIMIT_PER_MINUTE=200
API_RATE_LIMIT_PER_MINUTE=600
RATE_LIMIT_STORE=memory
RATE_LIMIT_REDIS_FAILURE_MODE=open
POSTGRES_AUTO_MIGRATE=true
API_LEGACY_DEPRECATION_DATE=Fri, 27 Feb 2026 00:00:00 GMT
API_LEGACY_SUNSET_DATE=Tue, 30 Jun 2026 23:59:59 GMT
HEALTH_READY_CACHE_TTL_MS=2000
HEALTH_READY_STALE_IF_ERROR_MS=15000
LOGGER_RETRY_MAX=0
LOGGER_RETRY_BACKOFF_BASE_MS=25
LOGGER_RETRY_BACKOFF_MAX_MS=100
LOGGER_WORKERS=2
LOGGER_DROP_ALERT_THRESHOLD_PCT=20
LOGGER_ALLOW_UNSIGNED_INGEST=true
MAX_INFLIGHT_REQUESTS=0
LOAD_SHED_EXEMPT_PREFIXES=/health,/metrics
